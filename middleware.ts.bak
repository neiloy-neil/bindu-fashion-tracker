import { withAuth } from "next-auth/middleware"
import { NextResponse } from "next/server"

export default withAuth(
  function middleware(req) {
    const role = req.nextauth.token?.role;
    const path = req.nextUrl.pathname;
    
    // Check if the current path falls under Admin-only domains
    const isAdminPath = 
      path.startsWith('/admin') || 
      path.startsWith('/parties') || 
      path.startsWith('/categories') || 
      path.startsWith('/api/admin') || 
      path.startsWith('/api/parties') || 
      path.startsWith('/api/categories');
    
    // If it's an admin path and the user is NOT an admin, restrict access
    if (isAdminPath && role !== 'ADMIN') {
      // For API routes, immediately return 401 Unauthorized
      if (path.startsWith('/api/')) {
        return new NextResponse(
          JSON.stringify({ error: "Unauthorized - Admin access required" }), 
          { 
            status: 401, 
            headers: { 'content-type': 'application/json' } 
          }
        );
      }
      
      // For Frontend routes, gracefully redirect back to the home/dashboard
      return NextResponse.redirect(new URL('/', req.url));
    }
    
    return NextResponse.next();
  },
  {
    callbacks: {
      // The `authorized` callback ensures the user is logged in.
      // If this returns true, the `middleware` function above executes.
      // If it returns false, NextAuth automatically redirects to `/login`.
      authorized: ({ token }) => !!token
    }
  }
)

export const config = {
  matcher: [
    /*
     * Match all protected paths:
     * - /admin and all subpaths
     * - /parties and all subpaths
     * - /categories and all subpaths
     * - /api/admin and all subpaths
     * - /api/parties and all subpaths
     * - /api/categories and all subpaths
     */
    '/admin/:path*',
    '/parties/:path*',
    '/categories/:path*',
    '/api/admin/:path*',
    '/api/parties/:path*',
    '/api/categories/:path*'
  ]
}
