// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id             Int                @id @default(autoincrement())
  name           String             @unique
  code           String?            @unique
  type           String             @default("RETAIL") // RETAIL, WHOLESALE, FACTORY
  address        String?            @db.Text
  contactPerson  String?
  phoneNumber    String?
  isActive        Boolean            @default(true)
  shiftStartTime  String             @default("09:00")
  pettyCashTarget Float              @default(0)
  createdAt       DateTime           @default(now())
  entries        DailyEntry[]
  attendances    Attendance[]
  users          User[]             @relation("UserPrimaryBranch")
  requests       BranchRequest[]
  managedBy      User[]             @relation("UserManagedBranches")
  ledgerAccounts LedgerAccount[]
  employees      Employee[]
  transfersOut   EmployeeTransfer[] @relation("BranchTransfersOut")
  transfersIn    EmployeeTransfer[] @relation("BranchTransfersIn")
}

model User {
  id                    Int                @id @default(autoincrement())
  username              String             @unique
  email                 String?            @unique
  passwordHash          String
  role                  String             @default("BRANCH") // ADMIN | SUPER_ADMIN | BRANCH | AUDITOR | AREA_MANAGER | HR_ADMIN | ACCOUNTS
  isActive              Boolean            @default(true)
  branchId              Int?
  branch                Branch?            @relation("UserPrimaryBranch", fields: [branchId], references: [id])
  editRequests          EditRequest[]
  comments              Comment[]
  accounts              Account[]
  sessions              Session[]
  branchRequests        BranchRequest[]
  assignedRequests      BranchRequest[]    @relation("AssignedBranchRequests")
  managedBranches       Branch[]           @relation("UserManagedBranches")
  approvedCheques       Cheque[]           @relation("ChequeApprover")
  auditLogs             AuditLog[]
  employeeTransfers     EmployeeTransfer[]
  createdAt             DateTime           @default(now())
  acknowledgedTransfers Transfer[]         @relation("TransferAcknowledger")
  salaryRecords         SalaryRecord[]
  approvedLeaves        LeaveRecord[]      @relation("LeaveApprover")
  notifications         Notification[]

  phoneNumber String?

  employeeId Int?      @unique
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}

model DailyEntry {
  id       Int      @id @default(autoincrement())
  date     DateTime
  branchId Int
  branch   Branch   @relation(fields: [branchId], references: [id])

  items EntryItem[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  receiptUrl         String?
  notes              String?
  actualPhysicalCash   Float?
  expectedNetBalance   Float?   @default(0)
  cashDifferenceNote   String?
  eodChecklist         Json?
  openingTime          String?
  closingTime          String?
  pettyCashOpening     Float    @default(0)
  pettyCashUsed        Float    @default(0)
  pettyCashReplenished Float    @default(0)
  pettyCashClosing     Float    @default(0)

  editRequests      EditRequest[]
  comments          Comment[]
  transfers         Transfer[]
  payments          Payment[]
  expenseEntries    ExpenseEntry[]
  advanceSalaries   AdvanceSalary[]
  receivedTransfers Transfer[]      @relation("ReceivedTransfers")

  @@unique([date, branchId])
  @@index([date])
  @@index([branchId])
}

model Category {
  id                Int            @id @default(autoincrement())
  name              String         @unique
  type              String // "INCOME" or "EXPENSE"
  isActive          Boolean        @default(true)
  isDefault         Boolean        @default(false)
  isAutoTransferred Boolean        @default(false)
  frequency         String? // DAILY | WEEKLY | MONTHLY | AS_NEEDED — only relevant for EXPENSE type
  createdAt         DateTime       @default(now())
  items             EntryItem[]
  expenseEntries    ExpenseEntry[]

  // Sub-category support
  parentId           Int?
  parent             Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children           Category[] @relation("CategoryChildren")
  requiresAttachment Boolean    @default(true)
  applicableTo       String[]   @default([]) // empty = all branch types; otherwise e.g. ["RETAIL","WHOLESALE"]
}

model EntryItem {
  id          Int        @id @default(autoincrement())
  entryId     Int
  entry       DailyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  categoryId  Int
  category    Category   @relation(fields: [categoryId], references: [id])
  amount      Float      @default(0)
  note        String?
  partyName   String?
  receiptUrls String[] // Can store multiple receipt URLs for an item

  @@unique([entryId, categoryId])
  @@index([categoryId])
}

model EditRequest {
  id            Int     @id @default(autoincrement())
  entryId       Int
  requestedById Int
  changes       String // Stored as JSON string
  reason        String?
  status        String  @default("PENDING") // PENDING, APPROVED, REJECTED

  entry       DailyEntry @relation(fields: [entryId], references: [id])
  requestedBy User       @relation(fields: [requestedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entryId])
  @@index([requestedById])
}

model Comment {
  id        Int        @id @default(autoincrement())
  entryId   Int
  entry     DailyEntry @relation(fields: [entryId], references: [id])
  userId    Int
  user      User       @relation(fields: [userId], references: [id])
  message   String     @db.Text
  createdAt DateTime   @default(now())

  @@index([entryId])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            Int
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BranchRequest {
  id            Int     @id @default(autoincrement())
  branchId      Int
  requestedById Int
  type          String // e.g., MAINTENANCE, SUPPLIES, STAFF, OTHER
  description   String  @db.Text
  status        String  @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, REJECTED
  priority      String  @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  adminComment  String? @db.Text
  attachmentUrl String?
  assignedToId  Int?

  branch      Branch @relation(fields: [branchId], references: [id])
  requestedBy User   @relation(fields: [requestedById], references: [id])
  assignedTo  User?  @relation("AssignedBranchRequests", fields: [assignedToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LedgerAccount {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  type      String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  transfers Transfer[]
  branchId  Int?
  branch    Branch?    @relation(fields: [branchId], references: [id])
}

model Transfer {
  id            Int      @id @default(autoincrement())
  dailyEntryId  Int
  accountId     Int
  amount        Float
  note          String?
  attachmentUrl String?
  createdAt     DateTime @default(now())

  dailyEntry DailyEntry    @relation(fields: [dailyEntryId], references: [id])
  account    LedgerAccount @relation(fields: [accountId], references: [id])

  status           String    @default("PENDING")
  acknowledgedById Int?
  acknowledgedBy   User?     @relation("TransferAcknowledger", fields: [acknowledgedById], references: [id])
  acknowledgedAt   DateTime?
  rejectionReason  String?

  receivingEntryId Int?
  receivingEntry   DailyEntry? @relation("ReceivedTransfers", fields: [receivingEntryId], references: [id])

  @@index([dailyEntryId])
  @@index([accountId, status])
  @@index([receivingEntryId])
  @@index([acknowledgedById])
}

model Party {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  contactPerson   String?
  contactNumber   String?
  secondaryNumber String?
  email           String?
  address         String?  @db.Text
  isActive        Boolean  @default(true)
  balance         Float    @default(0)
  createdAt       DateTime @default(now())

  payments  Payment[]
  bankInfo  PartyBankInfo[]
  purchases Purchase[]
}

model EmployeeTransfer {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  fromBranchId    Int
  toBranchId      Int
  transferredById Int
  transferDate    DateTime @default(now())
  reason          String?  @db.Text
  createdAt       DateTime @default(now())

  employee      Employee @relation(fields: [employeeId], references: [id])
  fromBranch    Branch   @relation("BranchTransfersOut", fields: [fromBranchId], references: [id])
  toBranch      Branch   @relation("BranchTransfersIn", fields: [toBranchId], references: [id])
  transferredBy User     @relation(fields: [transferredById], references: [id])

  @@index([employeeId])
  @@index([fromBranchId])
  @@index([toBranchId])
}

model PartyBankInfo {
  id          Int      @id @default(autoincrement())
  partyId     Int
  type        String   @default("BANK")
  label       String?
  accountNo   String
  accountName String?
  bankName    String?
  branchName  String?
  routingNo   String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  party    Party     @relation(fields: [partyId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@index([partyId])
}

model Purchase {
  id            Int      @id @default(autoincrement())
  partyId       Int
  date          DateTime
  amount        Float
  invoiceNumber String?
  note          String?
  attachmentUrl String?
  isOpeningDue  Boolean  @default(false)
  createdAt     DateTime @default(now())

  party Party @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@index([partyId])
}

model Payment {
  id             Int      @id @default(autoincrement())
  dailyEntryId   Int?
  partyId        Int
  method         String
  amount         Float
  note           String?
  attachmentUrl  String?
  approvalStatus String   @default("PENDING")
  createdAt      DateTime @default(now())

  partyBankInfoId Int?
  transactionRef  String?

  dailyEntry    DailyEntry?    @relation(fields: [dailyEntryId], references: [id])
  party         Party          @relation(fields: [partyId], references: [id], onDelete: Cascade)
  cheque        Cheque?
  partyBankInfo PartyBankInfo? @relation(fields: [partyBankInfoId], references: [id])

  @@index([partyId])
  @@index([dailyEntryId])
  @@index([partyBankInfoId])
}

model Cheque {
  id           Int       @id @default(autoincrement())
  paymentId    Int       @unique
  issueDate    DateTime
  withdrawDate DateTime
  status       String    @default("PENDING")
  approvedById Int?
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())

  payment    Payment @relation(fields: [paymentId], references: [id])
  approvedBy User?   @relation("ChequeApprover", fields: [approvedById], references: [id])
}

model ExpenseEntry {
  id              Int      @id @default(autoincrement())
  dailyEntryId    Int
  categoryId      Int
  amount          Float
  note            String?
  attachmentUrl   String?
  isTransferEntry Boolean  @default(false) // Auto-booked on acknowledge — excluded from expense totals in reports
  approvalStatus  String   @default("APPROVED") // PENDING | APPROVED | REJECTED
  rejectionReason String?
  createdAt       DateTime @default(now())

  dailyEntry DailyEntry @relation(fields: [dailyEntryId], references: [id])
  category   Category   @relation(fields: [categoryId], references: [id])

  @@index([dailyEntryId])
  @@index([categoryId])
  @@index([approvalStatus])
}

model Employee {
  id                   Int      @id @default(autoincrement())
  employeeId           String?  @unique
  name                 String
  designation          String?
  basicSalary          Float    @default(0)
  conveyance           Float    @default(1500)
  yearlyLeaveAllowance Int      @default(12)
  mobileNumber         String?
  dateOfBirth          String?
  joiningDate          String?
  address              String?  @db.Text
  emergencyContact     String?
  bloodGroup           String?
  nidNumber            String?
  oldIdCard            String?
  photoUrl             String?
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  branchId Int?
  branch   Branch? @relation(fields: [branchId], references: [id])

  advanceSalaries AdvanceSalary[]
  salaryRecords   SalaryRecord[]
  eidRecords      EidRecord[]
  leaveRecords    LeaveRecord[]

  user User?

  attendances Attendance[]
  transfers   EmployeeTransfer[]

  @@index([branchId])
}

model Attendance {
  id           Int       @id @default(autoincrement())
  date         DateTime
  checkInTime  DateTime
  checkOutTime DateTime? // Optional checkout time
  status       String // PRESENT, ABSENT, LATE, LEAVE
  isExcused    Boolean   @default(false)
  excuseNote   String?   @db.Text
  note         String?   @db.Text
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employeeId Int
  employee   Employee @relation(fields: [employeeId], references: [id])
  branchId   Int
  branch     Branch   @relation(fields: [branchId], references: [id])

  @@unique([employeeId, date])
  @@index([branchId, date])
}

model AdvanceSalary {
  id                 Int      @id @default(autoincrement())
  dailyEntryId       Int
  employeeId         Int
  type               String
  amount             Float?
  productDescription String?
  note               String?
  trackerSynced      Boolean  @default(true)
  createdAt          DateTime @default(now())

  dailyEntry DailyEntry @relation(fields: [dailyEntryId], references: [id])
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([employeeId, createdAt])
  @@index([dailyEntryId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String // CREATE, UPDATE, DELETE
  entityType String // e.g. DailyEntry, Payment, ExpenseEntry
  entityId   Int
  oldValues  String?  @db.Text
  newValues  String?  @db.Text
  reason     String?  @db.Text
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityId, entityType])
}

model SalaryRecord {
  id                  Int       @id @default(autoincrement())
  employeeId          Int
  employee            Employee  @relation(fields: [employeeId], references: [id])
  month               Int
  year                Int
  trackerAdvanceTotal Float     @default(0)
  hrAdvanceDeducted   Float     @default(0)
  leaveDaysTaken      Float     @default(0)
  leaveAdjustment     Float     @default(0)
  lateDays            Int       @default(0)
  otDays              Float     @default(0)
  attendanceBonus     Float     @default(0)
  conveyanceOverride  Float?
  notes               String    @default("") @db.Text
  lockedAt            DateTime?
  lockedById          Int?
  lockedBy            User?     @relation(fields: [lockedById], references: [id])
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([employeeId, month, year])
}

model EidRecord {
  id                  Int      @id @default(autoincrement())
  employeeId          Int
  employee            Employee @relation(fields: [employeeId], references: [id])
  title               String   @default("Eid Bonus")
  year                Int
  salaryPaymentPct    Float    @default(50)
  trackerAdvanceTotal Float    @default(0)
  hrAdvanceDeducted   Float    @default(0)
  eidBonusPct         Float    @default(50)
  createdAt           DateTime @default(now())

  @@unique([employeeId, year, title])
}

model LeaveRecord {
  id           Int      @id @default(autoincrement())
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id])
  startDate    DateTime
  endDate      DateTime
  type         String // SICK, CASUAL, UNPAID, ANNUAL, MARRIAGE
  status       String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reason       String?  @db.Text
  approvedById Int?
  approvedBy   User?    @relation("LeaveApprover", fields: [approvedById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
}

model SystemSettings {
  id          Int      @id @default(autoincrement())
  companyName String   @default("Bindu Premium")
  logoUrl     String?
  generatedBy String   @default("")
  paymentBy   String   @default("")
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // TRANSFER_INCOMING | GENERAL
  title     String
  body      String   @db.Text
  metadata  Json? // e.g. { transferId: 123, branchName: 'Mirpur' }
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
